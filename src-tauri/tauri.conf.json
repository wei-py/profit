      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "identifier": "com.xw.profit",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://profit-admin.xu-wei.space/api/files/releases/version.json"
      ],
